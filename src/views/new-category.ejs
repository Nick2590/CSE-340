<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <form action="/new-category" method="POST">
        <div class="form-group">
            <label for="categoryName">Category Name</label>
            <input
                type="text"
                id="categoryName"
                name="categoryName"
                required
                maxlength="100"
            />
        </div>

        <button type="submit">Create Category</button>
    </form>
</main>

<%- include('partials/footer') %>