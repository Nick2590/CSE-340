<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <p>Here are our partner organizations and how to connect with them.</p>

    <% if (organizations && organizations.length > 0) { %>
        <ul class="card-list">
            <% organizations.forEach((organization) => { %>
                <li class="card">
                    <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                    <div>
                        <h2>
                            <a href="/organization/<%= organization.organization_id %>">
                                <%= organization.name %>
                            </a>
                        </h2>
                        <p><%= organization.description %></p>
                        <p><strong>Email:</strong> <%= organization.contact_email %></p>
                    </div>
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>No organizations are available right now.</p>
    <% } %>
</main>

<%- include('partials/footer') %>