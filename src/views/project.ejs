<%- include('partials/header') %>

<main>
    <section class="project-details">
        <h1><%= project.title %></h1>

        <p>
            <strong>Description:</strong>
            <%= project.description %>
        </p>

        <p>
            <strong>Date:</strong>
            <%= new Date(project.date).toLocaleDateString() %>
        </p>

        <p>
            <strong>Location:</strong>
            <%= project.location %>
        </p>

        <p>
            <strong>Partner Organization:</strong>
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <p>
            <a href="/edit-project/<%= project.project_id %>">
                Edit Project
            </a>
        </p>

        <section class="project-categories">
            <h2>Categories</h2>

            <% if (categories.length > 0) { %>
                <div class="category-tags">
                    <% categories.forEach(category => { %>
                        <a
                            class="category-tag"
                            href="/category/<%= category.category_id %>"
                        >
                            <%= category.category_name %>
                        </a>
                    <% }) %>
                </div>
            <% } else { %>
                <p>No categories are assigned to this project.</p>
            <% } %>

            <p>
                <a href="/project/<%= project.project_id %>/assign-categories">
                    Edit Categories
                </a>
            </p>
        </section>

        <p>
            <a href="/projects">Back to Upcoming Projects</a>
        </p>
    </section>
</main>

<%- include('partials/footer') %>
