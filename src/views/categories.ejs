<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <p>Explore the categories that guide our service initiatives.</p>

    <% if (categories && categories.length > 0) { %>
        <ul class="card-list">
            <% categories.forEach((category) => { %>
                <li class="card">
                    <h2>
                        <a href="/category/<%= category.category_id %>">
                            <%= category.category_name %>
                        </a>
                    </h2>
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>No service project categories were found.</p>
    <% } %>
</main>

<%- include('partials/footer') %>