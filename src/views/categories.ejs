<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <% if (categories.length > 0) { %>
        <ul class="category-list">
            <% categories.forEach((category) => { %>
                <li><%= category.category_name %></li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>No service project categories were found.</p>
    <% } %>
</main>

<%- include('partials/footer') %>