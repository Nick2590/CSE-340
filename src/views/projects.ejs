<%- include('partials/header') %>

<main>
    <h2><%= title %></h2>

    <% if (projects && projects.length > 0) { %>
        <ul>
            <% projects.forEach(project => { %>
                <li>
                    <strong>
                        <%= new Date(project.project_date).toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        }) %>:
                    </strong>

                    <%= project.title %>
                    (<%= project.organization_name %>)

                    <br>

                    <%= project.description %>

                    <br>

                    <em>Location: <%= project.location %></em>
                </li>
                <br>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No service projects are currently available.</p>
    <% } %>
</main>

<%- include('partials/footer') %>