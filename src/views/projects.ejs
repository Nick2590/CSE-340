<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <% if (projects && projects.length > 0) { %>
        <ul class="card-list">
            <% projects.forEach((project) => { %>
                <li class="card">
                    <h2><%= project.title %></h2>
                    <p><strong>Organization:</strong> <%= project.organization_name %></p>
                    <p><strong>Category:</strong> <%= project.category_name %></p>
                    <p><strong>Date:</strong> <%= new Date(project.project_date).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                    }) %></p>
                    <p><%= project.description %></p>
                    <p><strong>Location:</strong> <%= project.location %></p>
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>No service projects are currently available.</p>
    <% } %>
</main>

<%- include('partials/footer') %>